# ContentPipe 环境变量配置示例
# 复制此文件为 .env.local（裸机）或 .env（Docker）并填入真实值
# 不要提交到仓库（已 gitignore）

# === OpenClaw Gateway（必填） ===
# Gateway 地址（Docker 内用 http://host.docker.internal:18789）
OPENCLAW_GATEWAY_URL=http://localhost:18789
# Gateway 认证 token（从 ~/.openclaw/openclaw.json → gateway.auth.token 获取）
# OPENCLAW_GATEWAY_TOKEN=your_gateway_token_here

# === Discord 通知（推荐） ===
# 审核通知推送到的 Discord 频道 ID
# CONTENTPIPE_NOTIFY_CHANNEL=1234567890123456789
# Discord Bot Token（Docker/云端必填；本地 OpenClaw 可自动从 openclaw.json 读取）
# DISCORD_BOT_TOKEN=MTxxxxxx.xxxxxx.xxxxxx
# Discord API 代理（国内服务器需要）
# DISCORD_PROXY=http://your-proxy:7890

# === ContentPipe 服务配置 ===
# CONTENTPIPE_PORT=8765
# CONTENTPIPE_HOST=0.0.0.0
# CONTENTPIPE_LOG_LEVEL=INFO
# Web UI 公网访问地址（用于通知消息中的链接）
# CONTENTPIPE_PUBLIC_BASE_URL=https://your-domain.com:8765
# Web UI 访问密码（留空则不需要登录）
# CONTENTPIPE_AUTH_TOKEN=your_secret_password

# === 微信公众号发布（可选） ===
# 如需自动创建公众号草稿，必须配置以下两项
# 同时需要在公众号后台把当前服务器出口 IP 加入白名单
# WECHAT_APPID=wx_your_app_id_here
# WECHAT_SECRET=your_app_secret_here

# === LLM API Keys（llm_mode=direct 时需要，gateway 模式不需要） ===
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# DASHSCOPE_API_KEY=sk-...
